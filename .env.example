# Port the broker listens on (default 8080)
PORT=8080

# Durable one-time OAuth state, handoff, and service-request replay storage.
DATABASE_URL=

# Abort provider API calls after this many milliseconds (default 10000).
PROVIDER_TIMEOUT_MS=10000

# Public base URL of THIS broker (no trailing slash). Used to build OAuth redirect_uri.
# e.g. https://connect.admitone.example.com
BROKER_PUBLIC_URL=

# --- Stripe Connect (platform account, Connect enabled) ---
# OAuth client id from your Connect settings, looks like ca_...
STRIPE_CONNECT_CLIENT_ID=
# Platform secret key (sk_live_... / sk_test_...). Used only for the token exchange.
STRIPE_PLATFORM_SECRET_KEY=

# --- Square OAuth (Square Developer app) ---
SQUARE_APP_ID=
SQUARE_APP_SECRET=
# production | sandbox
SQUARE_OAUTH_ENV=production
# Square API version header for OAuth token calls.
SQUARE_API_VERSION=2025-12-17
# Optional space-delimited override. Defaults to the documented payment/order scopes Showrunner needs.
SQUARE_OAUTH_SCOPES=

# Secret used to sign/verify the broker's own state token (HMAC-SHA256). Use a long random value.
ADMITONE_CONNECT_SIGNING_SECRET=

# Client registry as JSON. Keyed by clientId.
# returnOrigin must be HTTPS outside localhost and must not include path/query/hash.
# { "<clientId>": { "secret": "<sharedSecret>", "returnOrigin": "https://client.example.com" } }
ADMITONE_CONNECT_CLIENTS={}
