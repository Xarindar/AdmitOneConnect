{
  "name": "admitone-connect",
  "version": "1.0.0",
  "description": "AdmitOne Connect — a minimal OAuth broker for Showrunner client deployments (Stripe Connect / Square).",
  "type": "module",
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "8.20.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
